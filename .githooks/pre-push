#!/usr/bin/env bash
# pre-push — block pushes containing commits from blocked authors.
#
# Reads the same config keys as pre-commit:
#   git config hooks.blocked-author-emails   (comma-separated, globs ok)
#   git config hooks.blocked-author-pattern  (regex)

ZERO="0000000000000000000000000000000000000000"
BLOCKED_CSV=$(git config hooks.blocked-author-emails 2>/dev/null || echo "")
BLOCKED_RE=$(git config hooks.blocked-author-pattern 2>/dev/null || echo "")

[[ -z "$BLOCKED_CSV" && -z "$BLOCKED_RE" ]] && exit 0

_build_list() {
    IFS=',' read -ra _arr <<< "$BLOCKED_CSV"
    for _e in "${_arr[@]}"; do
        _e="${_e#"${_e%%[![:space:]]*}"}"
        _e="${_e%"${_e##*[![:space:]]}"}"
        [[ -n "$_e" ]] && echo "$_e"
    done
}

_is_blocked() {
    local email="$1"
    while IFS= read -r pat; do
        [[ -z "$pat" ]] && continue
        [[ "$email" == $pat ]] && return 0
    done < <(_build_list)
    [[ -n "$BLOCKED_RE" && "$email" =~ $BLOCKED_RE ]] && return 0
    return 1
}

found=0

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    [[ "$local_sha" == "$ZERO" ]] && continue
    range=$([[ "$remote_sha" == "$ZERO" ]] && echo "$local_sha" || echo "${remote_sha}..${local_sha}")

    while IFS=' ' read -r sha email name; do
        if _is_blocked "$email"; then
            echo ""
            echo "  ✖ Push blocked: commit from a blocked author."
            echo "    Commit : $sha"
            echo "    Author : $name <$email>"
            echo ""
            echo "  Rewrite with:"
            printf "    FILTER_BRANCH_SQUELCH_WARNING=1 git filter-branch -f --env-filter \\\n"
            printf '      '"'"'export GIT_AUTHOR_NAME="rubeecube"; export GIT_AUTHOR_EMAIL="rubeecube@users.noreply.github.com"; export GIT_COMMITTER_NAME="rubeecube"; export GIT_COMMITTER_EMAIL="rubeecube@users.noreply.github.com"'"'"' -- --branches\n'
            echo ""
            found=1
        fi
    done < <(git log --format="%H %ae %an" "$range" 2>/dev/null)
done

exit "$found"
