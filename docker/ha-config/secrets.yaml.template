# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is gitignored — never commit it.
#
# For the local validation stack (docker-compose), no real secrets are needed:
# GreenMail users are configured via GREENMAIL_OPTS and use test/test credentials.

# HA long-lived access token — required by validate.sh to call the REST API.
# Generate one at: http://localhost:8123/profile → Long-Lived Access Tokens
ha_token: "REPLACE_WITH_YOUR_HA_TOKEN"
